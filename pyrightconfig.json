{
  "include": [
    "featurizer"
  ],
  "exclude": [
    "**/__pycache__",
    "**/.venv",
    "**/node_modules"
  ],
  "pythonVersion": "3.10",
  "pythonPlatform": "Linux",
  "typeCheckingMode": "strict",
  "reportMissingTypeStubs": false,
  // Kept off under strict: the untyped third-party boundaries (records,
  // psycopg, pandas) otherwise produce ~360 reportUnknown* diagnostics with no
  // local fix. Tightening these is tracked as future work (see CHANGELOG).
  "reportUnknownMemberType": false,
  "reportUnknownArgumentType": false,
  "reportUnknownVariableType": false,
  "reportUnnecessaryIsInstance": "warning",
  "reportUnnecessaryComparison": "warning",
  "reportUnnecessaryCast": "warning",
  "reportIncompatibleMethodOverride": "error",
  "reportIncompatibleVariableOverride": "error",
  "reportInconsistentConstructor": "error",
  "ignore": [
    "featurizer/primitives/aggregations.py",
    "featurizer/primitives/transformations.py",
    "featurizer/viz"
  ]
}
